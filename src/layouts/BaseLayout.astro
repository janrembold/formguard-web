---
import '../styles/globals.scss';
import type { Lang } from '../i18n/utils';
import { localizePath } from '../i18n/utils';
import { SITE_URL } from '../data/constants';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	lang: Lang;
	title: string;
	description: string;
	/** Locale-neutral route, e.g. "/pricing" or "/". */
	path: string;
	/** Optional JSON-LD structured data objects. */
	jsonLd?: Record<string, unknown>[];
	ogImage?: string;
}

const { lang, title, description, path, jsonLd = [], ogImage = '/og-image.png' } = Astro.props;

const canonical = new URL(localizePath(path, lang), SITE_URL).href;
const deHref = new URL(localizePath(path, 'de'), SITE_URL).href;
const enHref = new URL(localizePath(path, 'en'), SITE_URL).href;
const ogImageUrl = new URL(ogImage, SITE_URL).href;
const ogLocale = lang === 'de' ? 'de_DE' : 'en_US';
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />

		<!-- Alternate languages -->
		<link rel="alternate" hreflang="de" href={deHref} />
		<link rel="alternate" hreflang="en" href={enHref} />
		<link rel="alternate" hreflang="x-default" href={deHref} />

		<!-- Icons & theme -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="theme-color" content="#4f46e5" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Submit API" />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<!-- Fonts: local, font-display swap -->
		<link rel="preconnect" href="https://rsms.me/" crossorigin />
		<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

		<!--
			Privacy-friendly analytics placeholder (e.g. Plausible).
			No cookies, no consent banner required. Enable by setting the domain.
		-->
		<!-- <script defer data-domain="submit-api.com" src="https://plausible.io/js/script.js"></script> -->

		{
			jsonLd.map((data) => (
				<script type="application/ld+json" set:html={JSON.stringify(data)} />
			))
		}
	</head>
	<body>
		<a class="skip-link" href="#main">{lang === 'de' ? 'Zum Inhalt springen' : 'Skip to content'}</a>
		<Header lang={lang} path={path} />
		<main id="main">
			<slot />
		</main>
		<Footer lang={lang} />

		<script>
			// Scroll reveal — progressive enhancement, respects reduced motion.
			const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const els = document.querySelectorAll<HTMLElement>('.reveal');
			if (prefersReduced || !('IntersectionObserver' in window)) {
				els.forEach((el) => el.classList.add('is-visible'));
			} else {
				const io = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								io.unobserve(entry.target);
							}
						}
					},
					{ rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
				);
				els.forEach((el) => io.observe(el));
			}
		</script>
	</body>
</html>
