---
import type { Lang } from '../i18n/utils';
import { useTranslations, localizePath } from '../i18n/utils';
import SectionHeading from './SectionHeading.astro';
import Button from './Button.astro';

interface Props {
	lang: Lang;
	/** Limit number of items shown (e.g. teaser on the home page). */
	limit?: number;
	/** Show a link to the full FAQ page. */
	showMore?: boolean;
	background?: 'default' | 'alt';
}

interface Item {
	q: string;
	a: string;
}

const { lang, limit, showMore = false, background = 'default' } = Astro.props;
const { t, tObj } = useTranslations(lang);
const all = tObj<Item[]>('faq.items');
const items = typeof limit === 'number' ? all.slice(0, limit) : all;
---

<section class:list={['faq', `faq--${background}`]} id="faq">
	<div class="container faq__inner">
		<SectionHeading title={t('faq.title')} subtitle={t('faq.subtitle')} />

		<div class="faq__list">
			{
				items.map((item) => (
					<details class="faq__item">
						<summary class="faq__summary">
							<span>{item.q}</span>
							<svg class="faq__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M6 9l6 6 6-6" />
							</svg>
						</summary>
						<div class="faq__answer">
							<p>{item.a}</p>
						</div>
					</details>
				))
			}
		</div>

		{
			showMore && (
				<div class="faq__more">
					<Button href={localizePath('/faq', lang)} variant="secondary" size="md">
						{t('cta.fullFaq')}
					</Button>
				</div>
			)
		}
	</div>
</section>

<style lang="scss">
	.faq {
		@include section-padding;
	}

	.faq--alt {
		background: var(--color-bg-alt);
		border-block: 1px solid var(--color-border);
	}

	.faq__inner {
		max-width: 800px;
	}

	.faq__list {
		display: grid;
		gap: var(--space-3);
	}

	.faq__item {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		overflow: hidden;

		&[open] {
			border-color: var(--color-primary-soft-2);
			box-shadow: var(--shadow-sm);
		}
	}

	.faq__summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		padding: var(--space-5);
		font-weight: 600;
		font-size: var(--text-lg);
		cursor: pointer;
		list-style: none;

		&::-webkit-details-marker {
			display: none;
		}

		&:hover {
			color: var(--color-primary);
		}
	}

	.faq__chevron {
		flex-shrink: 0;
		color: var(--color-text-subtle);
		transition: transform var(--transition-fast);
	}

	.faq__item[open] .faq__chevron {
		transform: rotate(180deg);
	}

	.faq__answer {
		padding: 0 var(--space-5) var(--space-5);
		color: var(--color-text-muted);
	}

	.faq__more {
		display: flex;
		justify-content: center;
		margin-top: var(--space-7);
	}

	@include reduced-motion {
		.faq__chevron {
			transition: none;
		}
	}
</style>
