---
import CodeSnippet from './CodeSnippet.astro';

interface Tab {
	id: string;
	label: string;
	code: string;
	lang: string;
}

interface Props {
	tabs: Tab[];
	copyLabel?: string;
	copiedLabel?: string;
	class?: string;
}

const { tabs, copyLabel = 'Copy', copiedLabel = 'Copied!', class: className } = Astro.props;
const groupId = `tabs-${Math.random().toString(36).slice(2, 9)}`;
---

<div class:list={['codetabs', className]} data-codetabs>
	<div class="codetabs__list" role="tablist" aria-label="Code examples">
		{
			tabs.map((tab, i) => (
				<button
					type="button"
					role="tab"
					id={`${groupId}-tab-${tab.id}`}
					class:list={['codetabs__tab', { 'is-active': i === 0 }]}
					aria-selected={i === 0 ? 'true' : 'false'}
					aria-controls={`${groupId}-panel-${tab.id}`}
					tabindex={i === 0 ? '0' : '-1'}
					data-tab={tab.id}
				>
					{tab.label}
				</button>
			))
		}
	</div>

	{
		tabs.map((tab, i) => (
			<div
				role="tabpanel"
				id={`${groupId}-panel-${tab.id}`}
				aria-labelledby={`${groupId}-tab-${tab.id}`}
				class="codetabs__panel"
				data-panel={tab.id}
				hidden={i !== 0}
			>
				<CodeSnippet
					code={tab.code}
					lang={tab.lang}
					copyLabel={copyLabel}
					copiedLabel={copiedLabel}
				/>
			</div>
		))
	}
</div>

<style lang="scss">
	.codetabs__list {
		display: inline-flex;
		gap: 2px;
		margin-bottom: var(--space-4);
		padding: 4px;
		background: var(--color-bg-alt);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		max-width: 100%;
		overflow-x: auto;
	}

	.codetabs__tab {
		padding: 0.5rem 0.9rem;
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-text-muted);
		background: transparent;
		border: none;
		border-radius: var(--radius-sm);
		cursor: pointer;
		white-space: nowrap;
		transition: background var(--transition-fast), color var(--transition-fast);

		&:hover {
			color: var(--color-text);
		}

		&.is-active {
			background: var(--color-surface);
			color: var(--color-primary);
			box-shadow: var(--shadow-sm);
		}
	}
</style>

<script>
	document.querySelectorAll<HTMLElement>('[data-codetabs]').forEach((group) => {
		const tabs = Array.from(group.querySelectorAll<HTMLButtonElement>('[data-tab]'));
		const panels = group.querySelectorAll<HTMLElement>('[data-panel]');

		const activate = (id: string, focus = false) => {
			tabs.forEach((tab) => {
				const active = tab.dataset.tab === id;
				tab.classList.toggle('is-active', active);
				tab.setAttribute('aria-selected', String(active));
				tab.tabIndex = active ? 0 : -1;
				if (active && focus) tab.focus();
			});
			panels.forEach((panel) => {
				panel.hidden = panel.dataset.panel !== id;
			});
		};

		tabs.forEach((tab, index) => {
			tab.addEventListener('click', () => activate(tab.dataset.tab ?? ''));
			tab.addEventListener('keydown', (e) => {
				if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
				e.preventDefault();
				const dir = e.key === 'ArrowRight' ? 1 : -1;
				const next = tabs[(index + dir + tabs.length) % tabs.length];
				activate(next.dataset.tab ?? '', true);
			});
		});
	});
</script>
