---
import type { Lang } from '../i18n/utils';
import { useTranslations, localizePath } from '../i18n/utils';
import { LOGIN_URL } from '../data/constants';
import Logo from './Logo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const { t } = useTranslations(lang);

const year = new Date().getFullYear();
const home = localizePath('/', lang);

const productLinks = [
	{ label: t('footer.links.features'), href: `${home === '/' ? '' : home.replace(/\/$/, '')}/#features` },
	{ label: t('footer.links.pricing'), href: localizePath('/pricing', lang) },
	{ label: t('footer.links.docs'), href: localizePath('/docs', lang) },
	{ label: t('footer.links.faq'), href: localizePath('/faq', lang) },
];

const legalLinks = [
	{ label: t('footer.links.impressum'), href: localizePath('/impressum', lang) },
	{ label: t('footer.links.datenschutz'), href: localizePath('/datenschutz', lang) },
];
---

<footer class="footer">
	<div class="container footer__inner">
		<div class="footer__brand">
			<a href={home} aria-label="Submit API"><Logo /></a>
			<p class="footer__desc">{t('footer.description')}</p>
			<p class="footer__eu">{t('footer.madeIn')}</p>
		</div>

		<div class="footer__col">
			<h2 class="footer__heading">{t('footer.product')}</h2>
			<ul>
				{productLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
				<li><a href={LOGIN_URL} rel="noopener">{t('footer.links.login')}</a></li>
			</ul>
		</div>

		<div class="footer__col">
			<h2 class="footer__heading">{t('footer.legal')}</h2>
			<ul>
				{legalLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
			</ul>
		</div>

		<div class="footer__col footer__col--lang">
			<h2 class="footer__heading">{t('nav.language')}</h2>
			<LanguageSwitcher lang={lang} path="/" />
		</div>
	</div>

	<div class="container footer__bottom">
		<p>© {year} Submit API. {t('footer.copyright')}</p>
	</div>
</footer>

<style lang="scss">
	.footer {
		margin-top: var(--space-16);
		padding-top: var(--space-12);
		background: var(--color-bg-alt);
		border-top: 1px solid var(--color-border);
	}

	.footer__inner {
		display: grid;
		gap: var(--space-8);
		grid-template-columns: 1fr;

		@include mq(sm) {
			grid-template-columns: 1fr 1fr;
		}

		@include mq(lg) {
			grid-template-columns: 2.2fr 1fr 1fr 1fr;
		}
	}

	.footer__brand {
		max-width: 360px;
	}

	.footer__desc {
		margin-top: var(--space-4);
		color: var(--color-text-muted);
		font-size: var(--text-sm);
	}

	.footer__eu {
		margin-top: var(--space-3);
		font-size: var(--text-xs);
		font-weight: 600;
		color: var(--color-text-subtle);
	}

	.footer__heading {
		font-size: var(--text-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-text-subtle);
		margin-bottom: var(--space-4);
	}

	.footer__col ul {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.footer__col a {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		text-decoration: none;

		&:hover {
			color: var(--color-primary);
		}
	}

	.footer__bottom {
		margin-top: var(--space-10);
		padding-block: var(--space-5);
		border-top: 1px solid var(--color-border);
		font-size: var(--text-sm);
		color: var(--color-text-subtle);
	}
</style>
