---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import Icon from './Icon.astro';

interface Props {
	lang: Lang;
}

interface Check {
	title: string;
	text: string;
}

const { lang } = Astro.props;
const { t, tObj } = useTranslations(lang);
const checks = tObj<Check[]>('security.checks');
---

<section class="security" id="security">
	<div class="container">
		<div class="security__header">
			<span class="security__eyebrow"><Icon name="lock" size={15} /> {t('logoCloud.badges.0')}</span>
			<h2 class="security__title">{t('security.title')}</h2>
			<p class="security__subtitle">{t('security.subtitle')}</p>
		</div>

		<ul class="security__grid">
			{
				checks.map((check) => (
					<li class="security__item reveal">
						<span class="security__check"><Icon name="check" size={15} /></span>
						<div>
							<h3 class="security__item-title">{check.title}</h3>
							<p class="security__item-text">{check.text}</p>
						</div>
					</li>
				))
			}
		</ul>

		<p class="security__note">
			<Icon name="shield" size={18} />
			{t('security.note')}
		</p>
	</div>
</section>

<style lang="scss">
	.security {
		@include section-padding;
		color: var(--color-dark-text);
		background:
			radial-gradient(70% 80% at 80% 0%, rgba(79, 70, 229, 0.22) 0%, transparent 60%),
			var(--color-dark-bg);
	}

	.security__header {
		max-width: 720px;
		margin-bottom: var(--space-8);
	}

	.security__eyebrow {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		font-size: var(--text-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--color-accent);
		margin-bottom: var(--space-3);
	}

	.security__title {
		font-size: var(--text-3xl);
		color: #fff;

		@include mq(md) {
			font-size: var(--text-4xl);
		}
	}

	.security__subtitle {
		margin-top: var(--space-4);
		font-size: var(--text-lg);
		color: var(--color-dark-muted);
	}

	.security__grid {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;

		@include mq(sm) {
			grid-template-columns: repeat(2, 1fr);
		}

		@include mq(lg) {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.security__item {
		display: flex;
		gap: var(--space-3);
		padding: var(--space-4) var(--space-5);
		background: var(--color-dark-surface);
		border: 1px solid var(--color-dark-border);
		border-radius: var(--radius-md);
	}

	.security__check {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 26px;
		height: 26px;
		color: var(--color-dark-bg);
		background: var(--color-accent);
		border-radius: 50%;
	}

	.security__item-title {
		font-size: var(--text-base);
		color: #fff;
		margin-bottom: 2px;
	}

	.security__item-text {
		font-size: var(--text-sm);
		color: var(--color-dark-muted);
	}

	.security__note {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		margin-top: var(--space-8);
		padding: var(--space-5);
		font-weight: 600;
		color: #fff;
		background: rgba(6, 182, 212, 0.1);
		border: 1px solid rgba(6, 182, 212, 0.35);
		border-radius: var(--radius-md);

		:global(svg) {
			color: var(--color-accent);
			flex-shrink: 0;
		}
	}
</style>
